{
  "name": "video-effects-studio",
  "version": "1.0.0",
  "description": "视频特效助手 - AI自动识别关键词生成特效",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.videoeffects.studio",
    "productName": "视频特效助手",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "src/**/*"
    ],
    "extraResources": [
      {
        "from": "bin",
        "to": "bin"
      },
      {
        "from": "fonts",
        "to": "fonts"
      }
    ],
    "win": {
      "target": "portable",
      "icon": null
    },
    "mac": {
      "target": "dmg",
      "icon": null
    }
  },
  "dependencies": {
    "hyperframes": "*"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.0.0"
  }
}
